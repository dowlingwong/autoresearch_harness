   "source": [
    "# Paper Figures -- Governed Agentic Experimentation (KDD AAE 2026)\n",
    "\n",
    "**Purpose:** Every figure maps directly to a claim or table in the paper.\n",
    "Each section header explains *why* the plot is needed and *what argument it supports*.\n",
    "\n",
    "**Data:** Loaded directly from append-only JSONL ledgers in `experiments/ledgers/`.\n",
    "\n",
    "**Style:** Consistent matplotlib style throughout (NeurIPS-width, 300 dpi).\n",
    "Run `Kernel -> Restart & Run All` to regenerate all outputs.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "7d06280b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Imports OK -- figures will be saved to: /Users/wongdowling/Documents/autoresearch_harness/paper/figures\n"
     ]
    }
   ],
   "source": [
    "import json, glob, os, warnings\n",
    "from collections import defaultdict\n",
    "from pathlib import Path\n",
    "import statistics\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "warnings.filterwarnings(\"ignore\")\n",
    "\n",
    "REPO        = Path(\"/Users/wongdowling/Documents/autoresearch_harness\")\n",
    "LEDGER_DIR  = REPO / \"experiments\" / \"ledgers\"\n",
    "TABLES_DIR  = REPO / \"paper\" / \"tables\"\n",
    "FIGURES_DIR = REPO / \"paper\" / \"figures\"\n",
    "FIGURES_DIR.mkdir(parents=True, exist_ok=True)\n",
    "\n",
    "# NeurIPS-compatible style\n",
    "plt.rcParams.update({\n",
    "    \"figure.dpi\": 150, \"savefig.dpi\": 300,\n",
    "    \"font.family\": \"serif\", \"font.size\": 10,\n",
    "    \"axes.titlesize\": 11, \"axes.labelsize\": 10,\n",
    "    \"xtick.labelsize\": 9, \"ytick.labelsize\": 9,\n",
    "    \"legend.fontsize\": 9, \"figure.figsize\": (7, 3.5),\n",
    "    \"axes.spines.top\": False, \"axes.spines.right\": False,\n",
    "    \"axes.grid\": True, \"grid.alpha\": 0.3, \"grid.linestyle\": \"--\",\n",
    "})\n",
    "\n",
    "C = {\n",
    "    \"none\":      \"#4C72B0\",\n",
    "    \"summary\":   \"#DD8452\",\n",
    "    \"rationale\": \"#55A868\",\n",
    "    \"kept\":      \"#4C72B0\",\n",
    "    \"discarded\": \"#DD8452\",\n",
    "    \"failed\":    \"#C44E52\",\n",
    "}\n",
    "print(\"Imports OK -- figures will be saved to:\", FIGURES_DIR)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a43dad64",
   "metadata": {},
   "source": [
    "## 1. Data Loader\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "42757fac",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Loaded 79 campaigns\n",
      "  lr_synthetic          : 30 campaigns,  600 trials\n",
      "  mlagentbench          :  2 campaigns,   20 trials\n",
      "  mlp_synthetic         : 12 campaigns,  300 trials\n",
      "  openml_bm             :  9 campaigns,  230 trials\n",
      "  openml_cg             :  9 campaigns,  230 trials\n",
      "  other                 :  8 campaigns,  211 trials\n",
      "  resnet_trigger        :  9 campaigns,  135 trials\n"
     ]
    }
   ],
   "source": [
    "def load_ledger(path):\n",
    "    trials = []\n",
    "    with open(path) as f:\n",
    "        for line in f:\n",
    "            line = line.strip()\n",
    "            if line:\n",
    "                try: trials.append(json.loads(line))\n",
    "                except: pass\n",
    "    return trials\n",
    "\n",
    "def get_metric(trial):\n",
    "    pm = trial.get(\"parsed_metrics\", {})\n",
    "    for k in [\"val_auc\", \"val_score\", \"auc\", \"accuracy\"]:\n",
    "        if k in pm and pm[k] is not None:\n",
    "            return float(pm[k])\n",
    "    return None\n",
    "\n",
    "def classify_node(fname):\n",
    "    if \"_lr_\" in fname:           return \"lr_synthetic\"\n",
    "    if \"_mlp_\" in fname:          return \"mlp_synthetic\"\n",
    "    if \"_mlagentbench_\" in fname: return \"mlagentbench\"\n",
    "    if \"_openml_bm_\" in fname:    return \"openml_bm\"\n",
    "    if \"_openml_cg_\" in fname:    return \"openml_cg\"\n",
    "    if \"_resnet_\" in fname:       return \"resnet_trigger\"\n",
    "    return \"other\"\n",
    "\n",
    "def classify_arm(fname):\n",
    "    if \"rationale\" in fname: return \"rationale\"\n",
    "    if \"_none_\" in fname:    return \"none\"\n",
    "    if \"summary\" in fname:   return \"summary\"\n",
    "    return \"unknown\"\n",
    "\n",
    "ALL_CAMPAIGNS = {}\n",
    "for path in sorted(LEDGER_DIR.glob(\"deepseek_*_trials.jsonl\")):\n",
    "    if \"smoke\" in path.name: continue\n",
    "    trials = load_ledger(path)\n",
    "    if not trials: continue\n",
    "    cid  = path.name.replace(\"_trials.jsonl\", \"\")\n",
    "    node = classify_node(path.name)\n",
    "    arm  = classify_arm(path.name)\n",
    "    kept   = [t for t in trials if t.get(\"decision\") == \"kept\"]\n",
    "    disc   = [t for t in trials if t.get(\"decision\") == \"discarded\"]\n",
    "    failed = [t for t in trials if t.get(\"decision\") == \"failed_invalid\"]\n",
    "    valid  = len(kept) + len(disc)\n",
    "    ALL_CAMPAIGNS[cid] = {\n",
    "        \"cid\": cid, \"node\": node, \"arm\": arm, \"trials\": trials,\n",
    "        \"kept\": kept, \"disc\": disc, \"failed\": failed, \"n\": len(trials),\n",
    "        \"ar\": len(kept)/valid if valid > 0 else None,\n",
    "        \"ir\": len(failed)/len(trials),\n",
    "    }\n",
    "\n",
    "nodes = defaultdict(list)\n",
    "for c in ALL_CAMPAIGNS.values():\n",
    "    nodes[c[\"node\"]].append(c)\n",
    "\n",
    "NODE_ORDER = [\"lr_synthetic\",\"mlp_synthetic\",\"mlagentbench\",\"openml_bm\",\"openml_cg\",\"resnet_trigger\"]\n",
    "NODE_LABELS = {\n",
    "    \"lr_synthetic\":   \"LR-Synthetic\",\n",
    "    \"mlp_synthetic\":  \"MLP-Synthetic\",\n",
    "    \"mlagentbench\":   \"MLAgentBench\",\n",
    "    \"openml_bm\":      \"OpenML-BM\",\n",
    "    \"openml_cg\":      \"OpenML-CG\",\n",
    "    \"resnet_trigger\": \"ResNet (env fail)\",\n",
    "}\n",
    "dec_colors = {\"kept\": C[\"kept\"], \"discarded\": C[\"discarded\"], \"failed_invalid\": C[\"failed\"]}\n",
    "\n",
    "print(f\"Loaded {len(ALL_CAMPAIGNS)} campaigns\")\n",
    "for node, cs in sorted(nodes.items()):\n",
    "    print(f\"  {node:<22}: {len(cs):>2} campaigns, {sum(c['n'] for c in cs):>4} trials\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "2e86c43c",
   "metadata": {},
   "source": [
    "## Figure 1 -- Governance Metrics Overview\n",
    "\n",
    "**Paper role (Sec 4.1):** Primary quantitative claim that every trial -- including\n",
    "failures -- carries a complete provenance chain and a categorised outcome. The stacked\n",
    "bar makes the kept/discarded/failed split visible at a glance across all 6 nodes.\n",
    "The colour-coded table shows provenance completeness = 100% universally, and flags\n",
    "which nodes have non-zero IR.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "e203972d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1800x570 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved fig1\n"
     ]
    }
   ],
   "source": [
    "rows = []\n",
    "for node in NODE_ORDER:\n",
    "    cs = nodes[node]\n",
    "    n_all  = sum(c[\"n\"]           for c in cs)\n",
    "    n_kept = sum(len(c[\"kept\"])   for c in cs)\n",
    "    n_disc = sum(len(c[\"disc\"])   for c in cs)\n",
    "    n_fail = sum(len(c[\"failed\"]) for c in cs)\n",
    "    n_prov = sum(\n",
    "        sum(1 for t in c[\"trials\"] if t.get(\"provenance\") and t[\"provenance\"].get(\"proposal_id\"))\n",
    "        for c in cs)\n",
    "    rows.append({\n",
    "        \"Node\": NODE_LABELS[node], \"Seeds\": len(cs), \"Trials\": n_all,\n",
    "        \"Kept (%)\": f\"{100*n_kept/n_all:.0f}\",\n",
    "        \"Disc (%)\": f\"{100*n_disc/n_all:.0f}\",\n",
    "        \"Fail (%)\": f\"{100*n_fail/n_all:.0f}\",\n",
    "        \"Prov 100%\": \"Yes\" if n_prov == n_all else f\"{n_prov}/{n_all}\",\n",
    "        \"_k\": n_kept, \"_d\": n_disc, \"_f\": n_fail, \"_n\": n_all,\n",
    "    })\n",
    "\n",
    "fig, (ax_tbl, ax_bar) = plt.subplots(1, 2, figsize=(12, 3.8),\n",
    "    gridspec_kw={\"width_ratios\": [1.35, 1]})\n",
    "ax_tbl.axis(\"off\")\n",
    "cols = [\"Node\",\"Seeds\",\"Trials\",\"Kept (%)\",\"Disc (%)\",\"Fail (%)\",\"Prov 100%\"]\n",
    "t = ax_tbl.table(\n",
    "    cellText=[r[c] for r in rows for c in cols].__class__([[r[c] for c in cols] for r in rows]),\n",
    "    colLabels=cols, loc=\"center\", cellLoc=\"center\")\n",
    "t.auto_set_font_size(False); t.set_fontsize(9); t.scale(1, 1.5)\n",
    "for i, r in enumerate(rows):\n",
    "    ir = float(r[\"Fail (%)\"])\n",
    "    clr = \"#d4f0dc\" if ir==0 else \"#fff3cd\" if ir<20 else \"#f8d7da\"\n",
    "    t[i+1,5].set_facecolor(clr)\n",
    "for j in range(len(cols)):\n",
    "    t[0,j].set_facecolor(\"#344D6E\"); t[0,j].set_text_props(color=\"white\",fontweight=\"bold\")\n",
    "ax_tbl.set_title(\"(a) Per-node scorecard\", fontweight=\"bold\")\n",
    "\n",
    "x = np.arange(len(NODE_ORDER)); w = 0.55\n",
    "kp = [100*r[\"_k\"]/r[\"_n\"] for r in rows]\n",
    "dp = [100*r[\"_d\"]/r[\"_n\"] for r in rows]\n",
    "fp = [100*r[\"_f\"]/r[\"_n\"] for r in rows]\n",
    "ax_bar.bar(x, kp, w, label=\"Kept\",      color=C[\"kept\"],      alpha=0.85)\n",
    "ax_bar.bar(x, dp, w, label=\"Discarded\", color=C[\"discarded\"], alpha=0.85, bottom=kp)\n",
    "ax_bar.bar(x, fp, w, label=\"Failed\",    color=C[\"failed\"],    alpha=0.85,\n",
    "           bottom=[k+d for k,d in zip(kp,dp)])\n",
    "ax_bar.set_xticks(x); ax_bar.set_xticklabels([NODE_LABELS[n] for n in NODE_ORDER],\n",
    "    rotation=30, ha=\"right\")\n",
    "ax_bar.set_ylabel(\"Trial proportion (%)\"); ax_bar.set_ylim(0,110)\n",
    "ax_bar.legend(loc=\"upper right\"); ax_bar.set_title(\"(b) Decision breakdown\", fontweight=\"bold\")\n",
    "ax_bar.annotate(\"MPS device failure\\novernight (env)\", xy=(5,50), fontsize=7.5,\n",
    "    color=\"#888\", ha=\"center\")\n",
    "fig.suptitle(\"Figure 1: Governance metrics across 6 nodes (495 total trials)\", y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig1_governance_overview.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig1_governance_overview.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig1\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b614ce59",
   "metadata": {},
   "source": [
    "## Figure 2 -- Memory-Mode Ablation (LR-Synthetic, 5 seeds x 3 arms)\n",
    "\n",
    "**Paper role (Sec 4.2):** Primary ablation result. Asks: does richer memory context\n",
    "change governance outcomes? LR-Synthetic gives the highest statistical power (5 seeds,\n",
    "0% IR). The result is a null finding -- AR is indistinguishable across arms -- which\n",
    "is itself honest and important: for simple hyperparameter optimisation the governance\n",
    "framework functions correctly regardless of memory mode.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "71b9d80b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1500x540 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved fig2\n"
     ]
    }
   ],
   "source": [
    "arm_labels = {\"none\": \"No Memory\", \"summary\": \"Summary\",\n",
    "              \"rationale\": \"Summary +\\nRationale\"}\n",
    "arms = [\"none\", \"summary\", \"rationale\"]\n",
    "arm_colors = [C[\"none\"], C[\"summary\"], C[\"rationale\"]]\n",
    "\n",
    "lr_campaigns = [c for c in ALL_CAMPAIGNS.values() if c[\"node\"] == \"lr_synthetic\"]\n",
    "arm_ars = {\"none\": [], \"summary\": [], \"rationale\": []}\n",
    "for c in lr_campaigns:\n",
    "    if c[\"arm\"] in arm_ars and c[\"ar\"] is not None:\n",
    "        arm_ars[c[\"arm\"]].append(c[\"ar\"])\n",
    "\n",
    "def seed_ci(vals, n_boot=10000):\n",
    "    m = statistics.mean(vals)\n",
    "    if len(vals) < 2: return m, m, m\n",
    "    rng = np.random.default_rng(42)\n",
    "    boots = [np.mean(rng.choice(vals, len(vals), replace=True)) for _ in range(n_boot)]\n",
    "    lo, hi = np.percentile(boots, [2.5, 97.5])\n",
    "    return m, lo, hi\n",
    "\n",
    "fig, (ax, ax2) = plt.subplots(1, 2, figsize=(10, 3.6))\n",
    "x = np.arange(len(arms))\n",
    "\n",
    "means, los, his = [], [], []\n",
    "for arm in arms:\n",
    "    m, lo, hi = seed_ci(arm_ars[arm])\n",
    "    means.append(m); los.append(lo); his.append(hi)\n",
    "\n",
    "ax.bar(x, means, 0.55, color=arm_colors, alpha=0.85, zorder=3)\n",
    "ax.errorbar(x, means,\n",
    "    yerr=[np.array(means)-np.array(los), np.array(his)-np.array(means)],\n",
    "    fmt=\"none\", color=\"black\", capsize=5, linewidth=1.5, zorder=4)\n",
    "for i, arm in enumerate(arms):\n",
    "    jitter = np.random.default_rng(i).uniform(-0.12, 0.12, len(arm_ars[arm]))\n",
    "    ax.scatter(i + jitter, arm_ars[arm], color=\"white\", edgecolors=\"black\",\n",
    "               s=30, zorder=5, linewidth=0.8)\n",
    "ax.set_xticks(x); ax.set_xticklabels([arm_labels[a] for a in arms])\n",
    "ax.set_ylabel(\"Acceptance Rate (kept / valid)\"); ax.set_ylim(0, 0.65)\n",
    "ax.axhline(statistics.mean(means), color=\"grey\", linestyle=\":\", linewidth=1,\n",
    "    label=f\"Grand mean = {statistics.mean(means):.3f}\")\n",
    "ax.legend(fontsize=8)\n",
    "ax.set_title(\"(a) Mean AR +/- 95% CI (seed-level bootstrap, n=5)\")\n",
    "\n",
    "for i, arm in enumerate(arms):\n",
    "    vals = arm_ars[arm]\n",
    "    jitter = np.random.default_rng(i+10).uniform(-0.15, 0.15, len(vals))\n",
    "    ax2.scatter(i + jitter, vals, color=arm_colors[i], s=60, alpha=0.8,\n",
    "                edgecolors=\"black\", linewidth=0.6, zorder=3)\n",
    "    ax2.hlines(statistics.mean(vals), i-0.25, i+0.25, colors=\"black\", linewidth=2)\n",
    "ax2.set_xticks(x); ax2.set_xticklabels([arm_labels[a] for a in arms])\n",
    "ax2.set_ylabel(\"Acceptance Rate (per seed)\"); ax2.set_ylim(-0.02, 0.75)\n",
    "ax2.set_title(\"(b) Per-seed distribution (bar = mean)\")\n",
    "ax2.annotate(\"High seed variance -> memory\\neffect not detectable at n=5\",\n",
    "    xy=(1,0.58), fontsize=8, ha=\"center\",\n",
    "    bbox=dict(boxstyle=\"round,pad=0.3\", fc=\"lightyellow\", alpha=0.8))\n",
    "fig.suptitle(\"Figure 2: Memory-mode ablation -- LR-Synthetic (150 trials, 5 seeds/arm)\", y=1.02)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig2_lr_ablation.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig2_lr_ablation.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig2\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "548db7f0",
   "metadata": {},
   "source": [
    "## Figure 3 -- Invalid Rate Taxonomy by Node\n",
    "\n",
    "**Paper role (Sec 4.3):** Shows the framework detects, categorises, and records every\n",
    "failure with no silent errors. IR spans 0% (synthetic nodes) to 100% (ResNet, env\n",
    "instability). Every bar's failure category is machine-readable in the JSONL ledger.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "aa38b522",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1350x570 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved fig3\n"
     ]
    }
   ],
   "source": [
    "fail_cats = defaultdict(lambda: defaultdict(int))\n",
    "node_totals = defaultdict(int)\n",
    "for c in ALL_CAMPAIGNS.values():\n",
    "    node_totals[c[\"node\"]] += c[\"n\"]\n",
    "    for t in c[\"failed\"]:\n",
    "        cat = t.get(\"failure_category\") or \"unknown\"\n",
    "        fail_cats[c[\"node\"]][cat] += 1\n",
    "\n",
    "cat_palette = {\n",
    "    \"runtime_error\": \"#C44E52\", \"metric_missing\": \"#DD8452\",\n",
    "    \"invalid_edit_scope\": \"#8172B2\", \"syntax_error\": \"#937860\",\n",
    "    \"no_op_patch\": \"#CCB974\", \"unknown\": \"#aaa\",\n",
    "}\n",
    "all_cats = sorted({c for d in fail_cats.values() for c in d})\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(9, 3.8))\n",
    "x = np.arange(len(NODE_ORDER)); bottoms = np.zeros(len(NODE_ORDER))\n",
    "for cat in all_cats:\n",
    "    vals = [100*fail_cats[n].get(cat,0)/node_totals[n] for n in NODE_ORDER]\n",
    "    ax.bar(x, vals, 0.6, bottom=bottoms, label=cat.replace(\"_\",\" \").title(),\n",
    "           color=cat_palette.get(cat,\"#aaa\"), alpha=0.88, zorder=3)\n",
    "    bottoms += np.array(vals)\n",
    "for i, node in enumerate(NODE_ORDER):\n",
    "    ir = 100*sum(fail_cats[node].values())/node_totals[node]\n",
    "    ax.text(i, ir+1.5, f\"{ir:.0f}%\", ha=\"center\", fontsize=8.5, fontweight=\"bold\")\n",
    "ax.set_xticks(x); ax.set_xticklabels([NODE_LABELS[n] for n in NODE_ORDER],\n",
    "    rotation=25, ha=\"right\")\n",
    "ax.set_ylabel(\"Invalid rate (% of all trials)\"); ax.set_ylim(0, 115)\n",
    "ax.legend(bbox_to_anchor=(1.01,1), loc=\"upper left\", framealpha=0.8)\n",
    "ax.set_title(\"Figure 3: Invalid rate by node and failure category\\n\"\n",
    "             \"Numbers = overall IR; all failures have a machine-readable category\")\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig3_ir_taxonomy.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig3_ir_taxonomy.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig3\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "77e1010d",
   "metadata": {},
   "source": [
    "## Figure 4 -- Trial Decision Timeline (OpenML-BM s1)\n",
    "\n",
    "**Paper role (Sec 3 / methodology):** Reader intuition for the control-plane loop.\n",
    "Shows the sequential kept/discarded/failed decisions alongside the running best metric.\n",
    "Illustrates that metric only advances at kept trials -- the keep rule is monotone by\n",
    "design, enforced by the control plane, not the LLM.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "9f91183b",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1500x750 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved fig4\n"
     ]
    }
   ],
   "source": [
    "rep = ALL_CAMPAIGNS[\"deepseek_openml_bm_s1\"]\n",
    "trials_s = sorted(rep[\"trials\"], key=lambda t: t.get(\"budget_index\", 0))\n",
    "indices  = [t.get(\"budget_index\", i+1) for i, t in enumerate(trials_s)]\n",
    "decisions = [t.get(\"decision\",\"unknown\") for t in trials_s]\n",
    "metrics   = [get_metric(t) for t in trials_s]\n",
    "\n",
    "running_best, cur = [], None\n",
    "for t in trials_s:\n",
    "    m = get_metric(t)\n",
    "    if t.get(\"decision\") == \"kept\" and m: cur = m\n",
    "    running_best.append(cur)\n",
    "\n",
    "fig, (ax_top, ax_bot) = plt.subplots(2, 1, figsize=(10, 5), sharex=True,\n",
    "    gridspec_kw={\"height_ratios\": [1, 1.4]})\n",
    "\n",
    "for idx, dec in zip(indices, decisions):\n",
    "    clr = dec_colors.get(dec, \"#aaa\")\n",
    "    ax_top.vlines(idx, 0, 1, colors=clr, alpha=0.7, linewidth=2.5)\n",
    "    ax_top.scatter([idx],[1], color=clr, s=60, edgecolors=\"white\", linewidth=0.5, zorder=3)\n",
    "ax_top.set_yticks([]); ax_top.set_ylabel(\"Decision\")\n",
    "ax_top.set_title(\"(a) Trial decisions -- deepseek_openml_bm_s1 (20 trials)\")\n",
    "legend_els = [mpatches.Patch(color=dec_colors[d], label=d.replace(\"_\",\" \").title())\n",
    "    for d in [\"kept\",\"discarded\",\"failed_invalid\"]]\n",
    "ax_top.legend(handles=legend_els, loc=\"upper right\", fontsize=8)\n",
    "\n",
    "ax_bot.step(indices, running_best, where=\"post\", color=C[\"kept\"], linewidth=2.2,\n",
    "    label=\"Running best\")\n",
    "for idx, dec, m in zip(indices, decisions, metrics):\n",
    "    if m is not None:\n",
    "        ax_bot.scatter(idx, m, color=dec_colors.get(dec,\"#aaa\"), s=35, zorder=4,\n",
    "            edgecolors=\"black\", linewidth=0.4, alpha=0.85)\n",
    "ax_bot.set_xlabel(\"Trial index\"); ax_bot.set_ylabel(\"val_AUC\")\n",
    "ax_bot.set_title(\"(b) Running best metric (step = kept; dots = all valid trials)\")\n",
    "ax_bot.legend(fontsize=8)\n",
    "\n",
    "# Annotate gain\n",
    "kb = [(idx,m) for idx,dec,m in zip(indices,decisions,metrics) if dec==\"kept\" and m]\n",
    "if kb:\n",
    "    gain = kb[-1][1]-kb[0][1]\n",
    "    ax_bot.annotate(f\"+{gain*100:.2f}pp campaign gain\",\n",
    "        xy=(kb[-1][0], kb[-1][1]), xytext=(kb[-1][0]-5, kb[-1][1]-0.003),\n",
    "        fontsize=8, ha=\"right\", arrowprops=dict(arrowstyle=\"->\", lw=1))\n",
    "\n",
    "fig.suptitle(\"Figure 4: One-trial-one-record discipline -- control plane owns keep/discard\",\n",
    "    y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig4_timeline.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig4_timeline.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig4\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "dc5d10ed",
   "metadata": {},
   "source": [
    "## Figure 5 -- Cross-Node AR and IR\n",
    "\n",
    "**Paper role (Sec 4.4):** Shows the same governed harness applies across 6 task types\n",
    "without modification. AR variation (22-60%) reflects task difficulty; IR variation\n",
    "(0-100%) reflects execution environment quality. Both are correctly captured by the\n",
    "framework -- not hidden or smoothed.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "76b0465d",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1650x600 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Saved fig5\n"
     ]
    }
   ],
   "source": [
    "summaries = []\n",
    "for node in NODE_ORDER:\n",
    "    cs = nodes[node]\n",
    "    n_all = sum(c[\"n\"] for c in cs)\n",
    "    n_kept= sum(len(c[\"kept\"]) for c in cs)\n",
    "    n_disc= sum(len(c[\"disc\"]) for c in cs)\n",
    "    n_fail= sum(len(c[\"failed\"]) for c in cs)\n",
    "    valid = n_kept + n_disc\n",
    "    ar = n_kept/valid if valid>0 else None\n",
    "    per_seed = [c[\"ar\"] for c in cs if c[\"ar\"] is not None]\n",
    "    if len(per_seed)>=2:\n",
    "        rng = np.random.default_rng(42)\n",
    "        boots = [np.mean(rng.choice(per_seed,len(per_seed),replace=True)) for _ in range(10000)]\n",
    "        ar_lo,ar_hi = np.percentile(boots,[2.5,97.5])\n",
    "    elif len(per_seed)==1: ar_lo=ar_hi=per_seed[0]\n",
    "    else: ar_lo=ar_hi=0\n",
    "    summaries.append({\"node\":node,\"ar\":ar,\"ar_lo\":ar_lo,\"ar_hi\":ar_hi,\n",
    "                      \"ir\":n_fail/n_all,\"n_seeds\":len(cs),\"n\":n_all})\n",
    "\n",
    "fig,(ax,ax2) = plt.subplots(1,2,figsize=(11,4))\n",
    "x = np.arange(len(NODE_ORDER)); w=0.6\n",
    "bar_colors = [\"#4C72B0\",\"#4C72B0\",\"#55A868\",\"#DD8452\",\"#DD8452\",\"#C44E52\"]\n",
    "\n",
    "ars    = [s[\"ar\"] or 0 for s in summaries]\n",
    "ar_los = [s[\"ar_lo\"] for s in summaries]\n",
    "ar_his = [s[\"ar_hi\"] for s in summaries]\n",
    "ax.bar(x, ars, w, color=bar_colors, alpha=0.82, zorder=3)\n",
    "ax.errorbar(x, ars, yerr=[np.array(ars)-np.array(ar_los),np.array(ar_his)-np.array(ars)],\n",
    "    fmt=\"none\", color=\"black\", capsize=4.5, linewidth=1.5, zorder=4)\n",
    "for i,s in enumerate(summaries):\n",
    "    label = f\"{s['ar']:.2f}\" if s[\"ar\"] else \"N/A\"\n",
    "    ax.text(i, (s[\"ar_hi\"] or 0)+0.025, label, ha=\"center\", fontsize=8.5, fontweight=\"bold\")\n",
    "ax.set_xticks(x); ax.set_xticklabels([NODE_LABELS[n] for n in NODE_ORDER],\n",
    "    rotation=30, ha=\"right\")\n",
    "ax.set_ylabel(\"Acceptance Rate (kept / valid)\"); ax.set_ylim(0, 0.95)\n",
    "ax.set_title(\"(a) Acceptance Rate by node\\n(95% CI, seed-level bootstrap)\")\n",
    "ax.legend(handles=[\n",
    "    mpatches.Patch(color=\"#4C72B0\",label=\"Synthetic\"),\n",
    "    mpatches.Patch(color=\"#55A868\",label=\"MLAgentBench\"),\n",
    "    mpatches.Patch(color=\"#DD8452\",label=\"OpenML\"),\n",
    "    mpatches.Patch(color=\"#C44E52\",label=\"ResNet (env fail)\"),\n",
    "], fontsize=8)\n",
    "\n",
    "irs = [s[\"ir\"] for s in summaries]\n",
    "ir_colors = [\"#d4f0dc\" if ir==0 else \"#fff3cd\" if ir<0.2 else \"#f8d7da\" for ir in irs]\n",
    "ax2.bar(x,[100*ir for ir in irs],w,color=ir_colors,edgecolor=\"black\",linewidth=0.6,alpha=0.9)\n",
    "for i,ir in enumerate(irs):\n",
    "    ax2.text(i,100*ir+1.5,f\"{100*ir:.0f}%\",ha=\"center\",fontsize=9,fontweight=\"bold\")\n",
    "ax2.set_xticks(x); ax2.set_xticklabels([NODE_LABELS[n] for n in NODE_ORDER],\n",
    "    rotation=30, ha=\"right\")\n",
    "ax2.set_ylabel(\"Invalid Rate (%)\"); ax2.set_ylim(0,115)\n",
    "ax2.axhline(5.8, color=\"grey\", linestyle=\"--\", linewidth=1,\n",
    "    label=\"Overall IR excl. ResNet = 5.8%\")\n",
    "ax2.legend(fontsize=8)\n",
    "ax2.set_title(\"(b) Invalid Rate by node\\n(green=0%, amber<20%, red>=20%)\")\n",
    "fig.suptitle(\"Figure 5: AR and IR across 6 nodes -- one harness, diverse tasks\", y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig5_cross_node.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig5_cross_node.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig5\")\n"
   ]
  },

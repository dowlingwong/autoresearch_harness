   "source": [
    "## Figure 9 -- ResNet Linux Ablation (NVIDIA L40S, 3 arms × 3 seeds × 15 trials)\n",
    "\n",
    "**Paper role (Sec 5.4):** Large-scale memory ablation on a real scientific task\n",
    "(near-threshold detector waveform classification). 135 total trials on deepthought2\n",
    "L40S. Confirms the memory hypothesis: `none < summary < rationale` by mean best AUC.\n",
    "Key new finding: memory dramatically reduces cross-seed variance (σ_none=0.257 vs σ_summary=0.004).\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bb2982fd",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json, os\n",
    "from pathlib import Path\n",
    "\n",
    "ARMS_LIN = ['none', 'append_only_summary', 'append_only_summary_with_rationale']\n",
    "ARM_LABELS_LIN = {\n",
    "    'none': 'No Memory',\n",
    "    'append_only_summary': 'Summary',\n",
    "    'append_only_summary_with_rationale': 'Summary+Rationale',\n",
    "}\n",
    "SEEDS_LIN = ['s1', 's2', 's3']\n",
    "LEDGER_DIR = REPO / 'experiments' / 'ledgers'  # use absolute path\n",
    "\n",
    "resnet_linux = {}\n",
    "for arm in ARMS_LIN:\n",
    "    resnet_linux[arm] = {}\n",
    "    for seed in SEEDS_LIN:\n",
    "        path = LEDGER_DIR / f'deepseek_resnet_{arm}_{seed}_trials.jsonl'\n",
    "        trials = [json.loads(l) for l in open(path)]\n",
    "        best = None\n",
    "        first_kept = None\n",
    "        traj = []   # (budget_index, best_so_far)\n",
    "        cur_best = None\n",
    "        for t in sorted(trials, key=lambda x: x.get('budget_index',0)):\n",
    "            mv = t.get('parsed_metrics',{}).get('val_auc')\n",
    "            if mv is not None: mv = float(mv)\n",
    "            if t.get('decision') == 'kept' and mv is not None:\n",
    "                if first_kept is None: first_kept = mv\n",
    "                if cur_best is None or mv > cur_best: cur_best = mv\n",
    "            traj.append((t.get('budget_index',0), cur_best))\n",
    "        resnet_linux[arm][seed] = {\n",
    "            'trials': trials,\n",
    "            'best_auc': max((float(t['parsed_metrics']['val_auc'])\n",
    "                             for t in trials if t.get('decision')=='kept'\n",
    "                             and 'val_auc' in t.get('parsed_metrics',{})), default=None),\n",
    "            'first_kept_auc': first_kept,\n",
    "            'trajectory': traj,\n",
    "            'n': len(trials),\n",
    "            'kept': sum(1 for t in trials if t.get('decision')=='kept'),\n",
    "            'discarded': sum(1 for t in trials if t.get('decision')=='discarded'),\n",
    "            'invalid': sum(1 for t in trials if t.get('decision')=='failed_invalid'),\n",
    "        }\n",
    "\n",
    "print(\"Loaded ResNet Linux data:\")\n",
    "for arm in ARMS_LIN:\n",
    "    bests = [resnet_linux[arm][s]['best_auc'] for s in SEEDS_LIN]\n",
    "    mean_b = sum(bests)/len(bests)\n",
    "    std_b = (sum((b-mean_b)**2 for b in bests)/len(bests))**0.5\n",
    "    accs = [resnet_linux[arm][s]['kept']/resnet_linux[arm][s]['n'] for s in SEEDS_LIN]\n",
    "    print(f\"  {ARM_LABELS_LIN[arm]:25}: mean_best={mean_b:.4f}±{std_b:.4f}  acc={sum(accs)/len(accs)*100:.1f}%  seeds={[round(b,4) for b in bests]}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "ff6f334b",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(11, 4))\n",
    "arm_list = ARMS_LIN\n",
    "x = np.arange(len(arm_list))\n",
    "w = 0.25\n",
    "colors = {'kept':'#2ecc71', 'discarded':'#e67e22', 'invalid':'#e74c3c'}\n",
    "\n",
    "# --- Left: acceptance / invalid rates per seed ---\n",
    "ax = axes[0]\n",
    "for si, seed in enumerate(SEEDS_LIN):\n",
    "    accs = [resnet_linux[arm][seed]['kept'] / resnet_linux[arm][seed]['n'] * 100 for arm in arm_list]\n",
    "    invs = [resnet_linux[arm][seed]['invalid'] / resnet_linux[arm][seed]['n'] * 100 for arm in arm_list]\n",
    "    offset = (si - 1) * w\n",
    "    ax.bar(x + offset, accs, w, label=f'{seed} acc', color='#2ecc71', alpha=0.5+si*0.15)\n",
    "    ax.bar(x + offset, invs, w, bottom=0, label=f'{seed} inv', color='#e74c3c', alpha=0.3+si*0.15, hatch='//')\n",
    "\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels([ARM_LABELS_LIN[a] for a in arm_list], fontsize=9)\n",
    "ax.set_ylabel('Rate (%)')\n",
    "ax.set_title('Acceptance (green) and Invalid (red hatched) Rate by Arm & Seed')\n",
    "ax.set_ylim(0, 70)\n",
    "\n",
    "# Pooled averages as thick lines\n",
    "for ai, arm in enumerate(arm_list):\n",
    "    mean_acc = sum(resnet_linux[arm][s]['kept']/resnet_linux[arm][s]['n'] for s in SEEDS_LIN)/3*100\n",
    "    ax.plot([ai-0.35, ai+0.35], [mean_acc, mean_acc], 'k-', lw=2.5, zorder=5)\n",
    "\n",
    "# --- Right: best AUC per seed (dot plot) ---\n",
    "ax2 = axes[1]\n",
    "for ai, arm in enumerate(arm_list):\n",
    "    bests = [resnet_linux[arm][s]['best_auc'] for s in SEEDS_LIN]\n",
    "    mean_b = sum(bests)/len(bests)\n",
    "    for bi, b in enumerate(bests):\n",
    "        ax2.scatter(ai, b, color='steelblue', s=80, zorder=3, alpha=0.8)\n",
    "    ax2.scatter(ai, mean_b, color='black', marker='D', s=100, zorder=4, label='mean' if ai==0 else '')\n",
    "    ax2.plot([ai]*len(bests), bests, 'steelblue', alpha=0.3, lw=1)\n",
    "\n",
    "ax2.set_xticks(range(len(arm_list)))\n",
    "ax2.set_xticklabels([ARM_LABELS_LIN[a] for a in arm_list], fontsize=9)\n",
    "ax2.set_ylabel('Best val_auc (per seed)')\n",
    "ax2.set_title('Best AUC per Seed — Memory Reduces Variance')\n",
    "ax2.set_ylim(0.0, 1.05)\n",
    "ax2.axhline(0.5, color='gray', ls='--', lw=1, label='random baseline')\n",
    "ax2.legend(fontsize=8)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / 'fig9_resnet_linux_ablation.svg', bbox_inches='tight')\n",
    "plt.savefig(FIGURES_DIR / 'fig9_resnet_linux_ablation.pdf', bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved fig9_resnet_linux_ablation\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d08defe8",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Best AUC trajectory by arm (mean over seeds + per-seed lines)\n",
    "fig, ax = plt.subplots(figsize=(8, 4))\n",
    "\n",
    "arm_colors = {'none':'#e74c3c', 'append_only_summary':'#f39c12', 'append_only_summary_with_rationale':'#2ecc71'}\n",
    "\n",
    "for arm in ARMS_LIN:\n",
    "    color = arm_colors[arm]\n",
    "    label = ARM_LABELS_LIN[arm]\n",
    "    all_trajs = []\n",
    "    for seed in SEEDS_LIN:\n",
    "        traj = resnet_linux[arm][seed]['trajectory']\n",
    "        # forward-fill None values\n",
    "        filled = []\n",
    "        last = None\n",
    "        for bi, v in traj:\n",
    "            if v is not None: last = v\n",
    "            filled.append(last or 0.0)\n",
    "        ax.plot(range(1, len(filled)+1), filled, color=color, alpha=0.25, lw=1.2)\n",
    "        all_trajs.append(filled)\n",
    "    # mean trajectory\n",
    "    mean_traj = [sum(t[i] for t in all_trajs)/len(all_trajs) for i in range(len(all_trajs[0]))]\n",
    "    ax.plot(range(1, len(mean_traj)+1), mean_traj, color=color, lw=2.5, label=label)\n",
    "\n",
    "ax.set_xlabel('Trial')\n",
    "ax.set_ylabel('Best val_auc (so far)')\n",
    "ax.set_title('ResNet Linux: Best AUC Trajectory by Memory Mode\\n(thick=mean over 3 seeds, thin=individual seeds)')\n",
    "ax.legend(fontsize=9)\n",
    "ax.set_xlim(1, 15)\n",
    "ax.set_ylim(0.0, 1.05)\n",
    "ax.axhline(0.5, color='gray', ls=':', lw=1, alpha=0.6)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / 'fig10_resnet_linux_trajectory.svg', bbox_inches='tight')\n",
    "plt.savefig(FIGURES_DIR / 'fig10_resnet_linux_trajectory.pdf', bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved fig10_resnet_linux_trajectory\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### ResNet Linux Key Findings (deepthought2, L40S, May 2026)\n",
    "\n",
    "| Arm | N | Acc% | Inv% | Mean Best AUC | Std (seeds) |\n",
    "|-----|---|------|------|---------------|-------------|\n",
    "| No Memory | 45 | 24.4% | 0.0% | 0.665 | ±0.257 |\n",
    "| Summary | 45 | 42.2% | 17.8% | 0.735 | ±0.004 |\n",
    "| Summary+Rationale | 45 | 35.6% | 15.6% | 0.798 | ±0.037 |\n",
    "\n",
    "**Confirmed:** Memory hypothesis `none < summary < rationale` by mean best AUC.\n",
    "\n",
    "**Key new finding:** Memory dramatically reduces cross-seed variance.\n",

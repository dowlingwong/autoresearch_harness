   "source": [
    "prov_rows = []\n",
    "for cid,c in ALL_CAMPAIGNS.items():\n",
    "    for t in c[\"trials\"]:\n",
    "        prov = t.get(\"provenance\",{})\n",
    "        has_prov  = bool(prov and prov.get(\"proposal_id\") and prov.get(\"decision_id\"))\n",
    "        has_log   = bool(t.get(\"raw_log_ref\"))\n",
    "        has_patch = bool(t.get(\"patch_ref\"))\n",
    "        has_metric= bool(t.get(\"parsed_metrics\"))\n",
    "        prov_rows.append({\n",
    "            \"node\": c[\"node\"], \"decision\": t.get(\"decision\",\"unknown\"),\n",
    "            \"has_prov\":has_prov,\"has_log\":has_log,\n",
    "            \"has_patch\":has_patch,\"has_metric\":has_metric,\n",
    "        })\n",
    "df_prov = pd.DataFrame(prov_rows)\n",
    "\n",
    "fig,(ax,ax2) = plt.subplots(1,2,figsize=(11,4))\n",
    "\n",
    "np_ = df_prov.groupby(\"node\")[\"has_prov\"].agg([\"sum\",\"count\"]).reset_index()\n",
    "np_[\"rate\"] = 100*np_[\"sum\"]/np_[\"count\"]\n",
    "np_[\"order\"] = np_[\"node\"].map({n:i for i,n in enumerate(NODE_ORDER)})\n",
    "np_ = np_.sort_values(\"order\").dropna(subset=[\"order\"]).reset_index(drop=True)\n",
    "ax.bar(range(len(np_)), np_[\"rate\"], color=\"#4C72B0\", alpha=0.85, edgecolor=\"black\", lw=0.5)\n",
    "for i,row in np_.iterrows():\n",
    "    ax.text(row[\"order\"], row[\"rate\"]+0.1, f\"{row['rate']:.0f}%\",\n",
    "        ha=\"center\", fontsize=9, fontweight=\"bold\")\n",
    "ax.set_xticks(range(len(np_)))\n",
    "ax.set_xticklabels([NODE_LABELS[n] for n in np_[\"node\"].tolist()], rotation=30, ha=\"right\")\n",
    "ax.set_ylabel(\"Provenance completeness (%)\"); ax.set_ylim(95,103)\n",
    "ax.axhline(100, color=\"green\", linestyle=\"--\", linewidth=1.2, label=\"100% target\")\n",
    "ax.legend(fontsize=8)\n",
    "ax.set_title(\"(a) Provenance chain completeness\\n(proposal->patch->run->metric->decision)\")\n",
    "\n",
    "for_dec = df_prov.groupby(\"decision\").agg(\n",
    "    n=(\"has_prov\",\"count\"), log=(\"has_log\",\"mean\"),\n",
    "    patch=(\"has_patch\",\"mean\"), metric=(\"has_metric\",\"mean\"),\n",
    "    prov=(\"has_prov\",\"mean\")).reset_index()\n",
    "decs=[\"kept\",\"discarded\",\"failed_invalid\"]\n",
    "dec_bar_colors=[C[\"kept\"],C[\"discarded\"],C[\"failed\"]]\n",
    "fields=[\"prov\",\"log\",\"patch\",\"metric\"]\n",
    "field_labels=[\"Prov. chain\",\"Raw log\",\"Patch diff\",\"Metric parsed\"]\n",
    "x2=np.arange(len(fields)); offsets=[-0.25,0,0.25]; w2=0.25\n",
    "for dec,clr,off in zip(decs,dec_bar_colors,offsets):\n",
    "    row=for_dec[for_dec[\"decision\"]==dec]\n",
    "    if row.empty: continue\n",
    "    vals=[float(row[f].values[0])*100 for f in fields]\n",
    "    n=int(row[\"n\"].values[0])\n",
    "    ax2.bar(x2+off,vals,w2,color=clr,alpha=0.85,\n",
    "        label=f\"{dec.replace('_',' ').title()} (n={n})\",edgecolor=\"black\",lw=0.4)\n",
    "ax2.set_xticks(x2); ax2.set_xticklabels(field_labels,rotation=20,ha=\"right\")\n",
    "ax2.set_ylabel(\"Capture rate (%)\"); ax2.set_ylim(80,105)\n",
    "ax2.legend(fontsize=8,framealpha=0.8)\n",
    "ax2.axhline(100,color=\"green\",linestyle=\"--\",lw=1,alpha=0.4)\n",
    "ax2.set_title(\"(b) Artifact capture rate by decision type\")\n",
    "fig.suptitle(\"Figure 6: Provenance and artifact completeness -- every trial is auditable\",y=1.01)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"fig6_provenance.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"fig6_provenance.png\", bbox_inches=\"tight\")\n",
    "plt.show(); print(\"Saved fig6\")\n"
   ]

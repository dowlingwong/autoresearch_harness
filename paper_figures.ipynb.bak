    "## Table 1 -- Paper-Facing Summary (camera-ready)\n",
    "\n",
    "**Paper role:** Table 1 in Results section. Export as CSV and as figure.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "09df7ffb",
   "metadata": {},
   "outputs": [],
   "source": [
    "summary_rows=[]\n",
    "for node in NODE_ORDER:\n",
    "    cs=nodes[node]\n",
    "    n_all=sum(c[\"n\"] for c in cs)\n",
    "    n_kept=sum(len(c[\"kept\"]) for c in cs)\n",
    "    n_disc=sum(len(c[\"disc\"]) for c in cs)\n",
    "    n_fail=sum(len(c[\"failed\"]) for c in cs)\n",
    "    valid=n_kept+n_disc\n",
    "    ar=n_kept/valid if valid>0 else None\n",
    "    per_seed=[c[\"ar\"] for c in cs if c[\"ar\"] is not None]\n",
    "    if len(per_seed)>=2:\n",
    "        rng=np.random.default_rng(42)\n",
    "        boots=[np.mean(rng.choice(per_seed,len(per_seed),replace=True)) for _ in range(10000)]\n",
    "        lo,hi=np.percentile(boots,[2.5,97.5])\n",
    "        ci_str=f\"[{lo:.2f},{hi:.2f}]\"\n",
    "    elif len(per_seed)==1: ci_str=\"--\"\n",
    "    else: ci_str=\"--\"\n",
    "    bests=[get_metric(t) for c in cs for t in c[\"kept\"] if get_metric(t) is not None]\n",
    "    best_str=f\"{max(bests):.4f}\" if bests else \"N/A*\"\n",
    "    n_prov=sum(sum(1 for t in c[\"trials\"] if t.get(\"provenance\") and\n",
    "        t[\"provenance\"].get(\"proposal_id\")) for c in cs)\n",
    "    summary_rows.append({\n",
    "        \"Node\":NODE_LABELS[node],\"Seeds\":len(cs),\"Trials\":n_all,\n",
    "        \"AR\":f\"{ar:.3f}\" if ar else \"N/A*\",\n",
    "        \"95% CI\":ci_str,\"IR\":f\"{100*n_fail/n_all:.1f}%\",\n",
    "        \"Best metric\":best_str,\n",
    "        \"Prov. 100%\":\"Yes\" if n_prov==n_all else f\"{n_prov}/{n_all}\",\n",
    "    })\n",
    "\n",
    "df_tbl=pd.DataFrame(summary_rows)\n",
    "df_tbl.to_csv(TABLES_DIR / \"table1_governance_summary.csv\", index=False)\n",
    "print(\"Saved table1_governance_summary.csv\")\n",
    "print(df_tbl.to_string(index=False))\n",
    "\n",
    "fig,ax=plt.subplots(figsize=(13,3.2))\n",
    "ax.axis(\"off\")\n",
    "t=ax.table(cellText=df_tbl.values.tolist(),colLabels=df_tbl.columns.tolist(),\n",
    "    loc=\"center\",cellLoc=\"center\")\n",
    "t.auto_set_font_size(False); t.set_fontsize(9); t.scale(1.0,1.8)\n",
    "for j in range(len(df_tbl.columns)):\n",
    "    t[0,j].set_facecolor(\"#344D6E\"); t[0,j].set_text_props(color=\"white\",fontweight=\"bold\")\n",
    "for i,r in enumerate(summary_rows):\n",
    "    ir=float(r[\"IR\"].replace(\"%\",\"\"))\n",
    "    clr=\"#d4f0dc\" if ir==0 else \"#fff3cd\" if ir<20 else \"#f8d7da\"\n",
    "    t[i+1,5].set_facecolor(clr)\n",
    "ax.set_title(\"Table 1: Per-node governance metrics (camera-ready)\", fontsize=10)\n",
    "plt.tight_layout()\n",
    "plt.savefig(FIGURES_DIR / \"table1_summary.pdf\", bbox_inches=\"tight\")\n",
    "plt.savefig(FIGURES_DIR / \"table1_summary.png\", bbox_inches=\"tight\")\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
